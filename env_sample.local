export OPENAI_VOICE_KEY="" # Not required if not using voice communication

# Agent Configuration
export AGENT=FinancialCompanionAgent
export AGENT_LLM=bedrock-claude-4-5-sonnet
export AGENT_LLM_PROVIDER=openai
export FINANCIAL_COMPANION_AGENT_LLM=bedrock-claude-4-5-haiku
