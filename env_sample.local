export TOOL_FAITHFULNESS_CLAIMS_EVALUATION_LLM=bedrock-claude-4-5-haiku
export TOOL_FAITHFULNESS_CLAIMS_EXTRACTION_LLM=bedrock-claude-4-5-haiku

# Development Settings
export IN_DEV=True
export DHP_NON_PROD=True
export SET_DHP_PROXY=False
export OTEL_LOG_LEVEL=debug
export LITELLM_LOG=WARNING
export SKIP_IDP_AUTH_CHECK=True

# A2A Protocol Configuration (Agent-to-Agent communication)
# Enable A2A protocol for inter-agent communication via JSON-RPC HTTP.
# When disabled (default), agents run in-process via direct Python calls.
# When enabled, agents communicate via HTTP JSON-RPC with automatic fallback.
# export A2A_ENABLED=True

# Enable A2A routing with in-process fallback for eligible agents.
# Requires A2A_ENABLED=True to have any effect.
# When True: Routes eligible agents via A2A, falls back to in-process on failure.
# When False: Uses in-process execution directly (even if A2A_ENABLED=True).
# export A2A_ROUTING_ENABLED=True

# Path to agent cards directory (default: common/a2a/agent_cards)
# Agent cards define agent metadata, capabilities, and routing rules.
# export A2A_CARDS_DIR=common/a2a/agent_cards

# Path to agents configuration file (default: common/a2a/config/a2a_agents.yaml)
# This YAML file lists all enabled internal and external agents.
# export A2A_AGENTS_CONFIG=common/a2a/config/a2a_agents.yaml

# HTTP timeout for A2A client requests in seconds (default: 30)
# export A2A_CLIENT_TIMEOUT_SECONDS=30

# Note: Agent server ports are configured in agent card files (common/a2a/agent_cards/*.json),
#       not via environment variables. Defaults: Products=8001, Savings=8002, Homeloans=8003.
#       See docs/a2a/a2a-implementation.md for details.

# Optional, but highly recommended: Langfuse Integration (See docs for detailed setup)
export LANGFUSE_FLAG=False
export LANGFUSE_SECRET_KEY=""
export LANGFUSE_PUBLIC_KEY=""
export LANGFUSE_HOST=http://localhost:3000
export USE_LANGFUSE_PROMPT=False

# Optional: Prompt Caching for Claude-supported orchestration calls
export ENABLE_INTENT_CLASSIFIER_PROMPT_CACHING=True
export ENABLE_SYNTHESIS_PROMPT_CACHING=True

# Optional: LaunchDarkly (See docs for setup)
export LAUNCHDARKLY_SDK_KEY="" # Ask an engineer/DS for this
export LAUNCHDARKLY_OFFLINE=True # Set to True for local development without connecting to LaunchDarkly
export LAUNCHDARKLY_DISABLE_SSL_VERIFICATION=True

