FROM applicationinfrastructure-public.docker.internal.cba/ca-certificates:latest AS certificates
FROM applicationinfrastructure-public.docker.internal.cba/library/python:3.12-slim@sha256:d9a9a1b7265f2c3ea499b6367434853072b0e4abd376a5a79626a14d655eb079 AS bookworm-repo-settings

FROM hub.docker.internal.cba/python:3.13-slim-bookworm AS base

COPY --from=certificates roots/ /etc/ssl/certs
COPY --from=certificates internal/ /usr/local/share/ca-certificates/
COPY --from=bookworm-repo-settings /etc/apt/sources.list.d/debian.sources /etc/apt/sources.list.d/debian.sources

# Combine certificate update and package installation
RUN update-ca-certificates && \
    apt-get update && \
    apt-get install -y curl jq vim git nodejs npm && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt/defaultsite

# Set environment variables early
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
    REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt \
    APP_NAME=companion

# Copy lock files first for better layer caching
COPY pyproject.toml uv.lock ./
COPY init.sh /opt/defaultsite/

# Copy required files for Claude
RUN mkdir -p /opt/defaultsite/.claude/commands
COPY .claude/ /opt/defaultsite/.claude

# Install Claude - shouldn't change so higher priority
RUN ./init.sh

# Install uv and Python dependencies
RUN pip install uv==0.10.11 \
    --no-cache-dir \
    --index-url https://artifactory.internal.cba/artifactory/api/pypi/org.python.pypi/simple && \
    uv sync --frozen --group dev --no-cache --no-install-project

# Configure PATH to use uv virtual environment
ENV VIRTUAL_ENV=/opt/defaultsite/.venv \
    PATH="/opt/defaultsite/.venv/bin:$PATH"

# Uncomment below to install observability package and test ROTI integration locally
# RUN --mount=type=secret,id=artifactory_user \
#     --mount=type=secret,id=artifactory_key \
#     uv pip install \
#     --index-url "https://$(cat /run/secrets/artifactory_user):$(cat /run/secrets/artifactory_key)@artifactory.internal.cba/artifactory/api/pypi/dea-observability-pypi/simple/" \
#     "observability" "langgraph-prebuilt==1.0.8"

# Copy application code (in order of change frequency - least to most)
COPY common ./common
COPY apps/companion/ ./apps/companion/

COPY tests/ ./tests/
COPY scripts/ ./scripts/

# Running evals needs workdir added to PYTHONPATH
ENV PYTHONPATH=/opt/defaultsite
